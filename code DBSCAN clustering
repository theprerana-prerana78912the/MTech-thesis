# Focus on the DBSCAN algorithm implementation and conceptual framework

import numpy as np
import os
from sklearn.cluster import DBSCAN
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA
from sklearn.metrics import silhouette_score
import matplotlib.pyplot as plt
import pickle
from pathlib import Path

class VideoFrameClusteringDBSCAN:
    """
    DBSCAN-based video frame clustering implementation
    Based on the algorithm described in the provided document
    """
    
    def __init__(self, eps=0.5, min_pts=2):
        """
        Initialize DBSCAN clustering for video frames
        
        Args:
            eps: Maximum distance between two samples for neighborhood
            min_pts: Minimum number of samples in neighborhood for core point
        """
        self.eps = eps
        self.min_pts = min_pts
        self.dbscan_model = None
        self.scaler = None
        self.pca = None
        self.cluster_labels = None
        self.features = None
        
    def preprocess_features(self, features, apply_pca=True, n_components=50):
        """
        Preprocess features using standardization and optional PCA
        
        Args:
            features: Raw feature matrix (n_samples x n_features)
            apply_pca: Whether to apply PCA for dimensionality reduction
            n_components: Number of PCA components
            
        Returns:
            Preprocessed features
        """
        # Standardize features
        self.scaler = StandardScaler()
        features_scaled = self.scaler.fit_transform(features)
        
        # Apply PCA if features are high-dimensional
        if apply_pca and features_scaled.shape[1] > n_components:
            self.pca = PCA(n_components=n_components)
            features_scaled = self.pca.fit_transform(features_scaled)
            print(f"Applied PCA: {features.shape[1]} -> {features_scaled.shape[1]} dimensions")
            print(f"Explained variance ratio: {self.pca.explained_variance_ratio_.sum():.3f}")
        
        return features_scaled
    
    def fit_predict(self, features):
        """
        Apply DBSCAN clustering to video frame features
        
        Args:
            features: Feature matrix (n_frames x n_features)
            
        Returns:
            cluster_labels: Array of cluster labels for each frame
        """
        # Store original features
        self.features = features
        
        # Preprocess features
        features_processed = self.preprocess_features(features)
        
        # Apply DBSCAN clustering
        self.dbscan_model = DBSCAN(eps=self.eps, min_samples=self.min_pts)
        self.cluster_labels = self.dbscan_model.fit_predict(features_processed)
        
        # Print clustering results
        n_clusters = len(set(self.cluster_labels)) - (1 if -1 in self.cluster_labels else 0)
        n_noise = list(self.cluster_labels).count(-1)
        n_core_samples = len(self.dbscan_model.core_sample_indices_)
        
        print(f"DBSCAN Clustering Results:")
        print(f"  Number of clusters: {n_clusters}")
        print(f"  Number of noise points: {n_noise}")
        print(f"  Number of core samples: {n_core_samples}")
        print(f"  Eps: {self.eps}, MinPts: {self.min_pts}")
        
        return self.cluster_labels
    
    def optimize_parameters(self, features, eps_range=(0.1, 2.0), min_pts_range=(2, 10)):
        """
        Find optimal DBSCAN parameters using silhouette score
        
        Args:
            features: Feature matrix
            eps_range: Range of eps values to try
            min_pts_range: Range of min_pts values to try
            
        Returns:
            best_params: Dictionary with best parameters
            results: List of all parameter combinations and scores
        """
        # Preprocess features
        features_processed = self.preprocess_features(features)
        
        best_score = -1
        best_params = {}
        results = []
        
        eps_values = np.linspace(eps_range[0], eps_range[1], 10)
        min_pts_values = range(min_pts_range[0], min_pts_range[1] + 1)
        
        print("Optimizing DBSCAN parameters...")
        
        for eps in eps_values:
            for min_pts in min_pts_values:
                dbscan = DBSCAN(eps=eps, min_samples=min_pts)
                labels = dbscan.fit_predict(features_processed)
                
                # Skip if all points are noise or all in one cluster
                n_clusters = len(set(labels)) - (1 if -1 in labels else 0)
                if n_clusters < 2:
                    continue
                    
                # Calculate silhouette score
                try:
                    score = silhouette_score(features_processed, labels)
                    results.append({
                        'eps': eps,
                        'min_pts': min_pts,
                        'n_clusters': n_clusters,
                        'silhouette_score': score,
                        'n_noise': list(labels).count(-1)
                    })
                    
                    if score > best_score:
                        best_score = score
                        best_params = {
                            'eps': eps,
                            'min_pts': min_pts,
                            'n_clusters': n_clusters,
                            'silhouette_score': score,
                            'n_noise': list(labels).count(-1)
                        }
                except:
                    continue
        
        if best_params:
            print(f"Best parameters found:")
            print(f"  eps={best_params['eps']:.3f}, min_pts={best_params['min_pts']}")
            print(f"  silhouette score: {best_params['silhouette_score']:.3f}")
            print(f"  clusters: {best_params['n_clusters']}, noise points: {best_params['n_noise']}")
            
            # Update model parameters
            self.eps = best_params['eps']
            self.min_pts = best_params['min_pts']
        
        return best_params, results
    
    def get_cluster_statistics(self):
        """
        Get detailed statistics about clusters
        
        Returns:
            Dictionary with cluster statistics
        """
        if self.cluster_labels is None:
            raise ValueError("Must fit model first")
            
        unique_labels = set(self.cluster_labels)
        stats = {}
        
        for cluster_id in unique_labels:
            mask = self.cluster_labels == cluster_id
            cluster_size = np.sum(mask)
            
            if cluster_id == -1:
                stats['noise'] = {
                    'size': cluster_size,
                    'percentage': cluster_size / len(self.cluster_labels) * 100
                }
            else:
                stats[f'cluster_{cluster_id}'] = {
                    'size': cluster_size,
                    'percentage': cluster_size / len(self.cluster_labels) * 100,
                    'frame_indices': np.where(mask)[0].tolist()
                }
        
        return stats
    
    def get_representative_frames(self, n_representatives=3):
        """
        Get representative frames from each cluster
        
        Args:
            n_representatives: Number of representative frames per cluster
            
        Returns:
            Dictionary mapping cluster_id to representative frame indices
        """
        if self.cluster_labels is None or self.features is None:
            raise ValueError("Must fit model first")
            
        representatives = {}
        unique_labels = set(self.cluster_labels)
        
        for cluster_id in unique_labels:
            if cluster_id == -1:  # Skip noise
                continue
                
            cluster_mask = self.cluster_labels == cluster_id
            cluster_features = self.features[cluster_mask]
            cluster_indices = np.where(cluster_mask)[0]
            
            if len(cluster_features) <= n_representatives:
                # If cluster has fewer frames than requested, take all
                representatives[cluster_id] = cluster_indices.tolist()
            else:
                # Use simple clustering or random sampling within cluster
                # For simplicity, we'll use indices spread across the cluster
                step = len(cluster_indices) // n_representatives
                rep_indices = cluster_indices[::step][:n_representatives]
                representatives[cluster_id] = rep_indices.tolist()
        
        return representatives

# Demonstration with synthetic video frame features
def create_synthetic_video_features(n_frames=100, n_features=256, n_scenes=4):
    """
    Create synthetic video frame features for demonstration
    Simulates different scenes in a video
    
    Args:
        n_frames: Total number of frames
        n_features: Number of features per frame
        n_scenes: Number of distinct scenes
        
    Returns:
        features: Synthetic feature matrix
        true_labels: Ground truth scene labels
    """
    print(f"Creating synthetic video with {n_frames} frames, {n_features} features, {n_scenes} scenes")
    
    features = []
    true_labels = []
    
    frames_per_scene = n_frames // n_scenes
    
    for scene_id in range(n_scenes):
        # Create scene-specific features with some noise
        scene_center = np.random.randn(n_features) * 2
        
        start_frame = scene_id * frames_per_scene
        end_frame = min((scene_id + 1) * frames_per_scene, n_frames)
        
        for frame_idx in range(start_frame, end_frame):
            # Add noise to scene center to create frame features
            frame_features = scene_center + np.random.randn(n_features) * 0.5
            features.append(frame_features)
            true_labels.append(scene_id)
    
    return np.array(features), np.array(true_labels)

# Example usage and demonstration
print("DBSCAN Video Frame Clustering Implementation")
print("=" * 50)

# Create synthetic video data for demonstration
features, true_labels = create_synthetic_video_features(n_frames=120, n_features=256, n_scenes=5)
print(f"Synthetic video features shape: {features.shape}")

# Initialize DBSCAN clustering
clustering = VideoFrameClusteringDBSCAN()

# Optimize parameters
print("\nOptimizing DBSCAN parameters...")
best_params, optimization_results = clustering.optimize_parameters(features)

# Apply clustering with optimized parameters
print("\nApplying DBSCAN clustering...")
